# ============================================================
# RoofBack — Environment Variables
# Copy to .env.local and fill in values.
# Never commit .env.local or real secrets.
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=

# Site URL (used for auth redirects, proposal links, PDF logo)
NEXT_PUBLIC_SITE_URL=https://roofback.app

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Anthropic AI (for improve-description, business-insights)
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps (optional, for address autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Debug page (optional, dev only — set to enable /debug)
DEBUG_PAGE_SECRET=

# Vercel / Netlify (auto-set in deployment)
# VERCEL_URL=
# URL=
